# BankMore — variáveis de ambiente
# Copie para .env e ajuste para o seu ambiente. .env não vai pro git.

# ====================================================================
# Postgres
# ====================================================================
POSTGRES_USER=bankmore
POSTGRES_PASSWORD=bankmore123
POSTGRES_DB=bankmore_db

# ====================================================================
# JWT — DEV. Em produção: gerar 64+ chars cripto-seguros e usar um
# secret store (AWS SM, Vault, Azure Key Vault).
# ====================================================================
JWT_KEY=DEV-ONLY-CHANGE-ME-IN-PROD-min-32-chars-please-1234567890

# ====================================================================
# Kafka — endpoints internos (containers) e externos (host)
# ====================================================================
KAFKA_BROKER_INTERNAL=kafka:29092
KAFKA_BROKER_EXTERNAL=localhost:9092
